{
  "name": "discrypt-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:command-coverage": "node scripts/command-coverage-check.mjs",
    "test:production-copy": "node scripts/command-coverage-check.mjs",
    "test:e2e": "VITE_DISCRYPT_LOCAL_DEV_FALLBACK=1 vite build && playwright test",
    "test:honesty": "node scripts/honesty-gates.mjs",
    "release:linux": "node ../../scripts/release-linux.mjs",
    "release:linux:dry-run": "node ../../scripts/release-linux.mjs --dry-run",
    "test:release-linux": "node ../../scripts/check-release-linux.mjs",
    "test:linux-runtime-docs": "node ../../scripts/check-linux-runtime-docs.mjs",
    "smoke:linux-packages": "node ../../scripts/smoke-linux-packages.mjs",
    "smoke:linux-packages:dry-run": "node ../../scripts/smoke-linux-packages.mjs --dry-run",
    "test:linux-package-smoke": "node ../../scripts/check-linux-package-smoke.mjs",
    "test:desktop-package-ci": "node ../../scripts/check-desktop-package-ci.mjs",
    "test:android-gate": "node ../../scripts/check-android-gate.mjs",
    "test:signaling-relay-ops": "node ../../scripts/check-signaling-relay-ops.mjs",
    "test:release-governance": "node ../../scripts/check-release-governance.mjs",
    "test:release-verification-matrix": "node ../../scripts/check-release-verification-matrix.mjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "6.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.14"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "playwright": "^1.60.0"
  }
}
