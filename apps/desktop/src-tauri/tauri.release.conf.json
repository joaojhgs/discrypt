{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "discrypt",
  "version": "0.1.0",
  "identifier": "chat.discrypt.desktop",
  "build": {
    "features": [
      "tauri-runtime",
      "production-network",
      "production-media",
      "production-storage",
      "mqtt-adapter",
      "nostr-adapter",
      "ipfs-pubsub-adapter",
      "discrypt-quic-rendezvous-adapter"
    ],
    "beforeDevCommand": "cd ../ui && npm run dev -- --host 127.0.0.1 --port 1420 --strictPort",
    "beforeBuildCommand": "cd ../ui && npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "discrypt",
        "width": 1200,
        "height": 800,
        "minWidth": 360,
        "minHeight": 640,
        "resizable": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": [
          "gnome-keyring",
          "dbus-user-session",
          "libpam-gnome-keyring"
        ]
      },
      "rpm": {
        "depends": [
          "gnome-keyring"
        ]
      }
    }
  }
}
